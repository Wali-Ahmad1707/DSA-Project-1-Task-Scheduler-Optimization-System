# cpsat_solver.py
from ortools.sat.python import cp_model
import csv

def read_csvs(tasks_csv="tasks.csv", resources_csv="resources.csv"):
    import greedy
    return greedy.load_tasks(tasks_csv), greedy.load_resources(resources_csv)

def solve_cpsat(tasks, resources, horizon=72, objective="lateness"):
    m = cp_model.CpModel()
    H = horizon

    # Indexing
    T = {t["task_id"]: t for t in tasks}
    R = {r["res_id"]: r for r in resources}
    skills = {rid: R[rid]["skills"] for rid in R}

    # Decision vars
    start = {tid: m.NewIntVar(0, H, f"start_{tid}") for tid in T}
    end   = {tid: m.NewIntVar(0, H, f"end_{tid}") for tid in T}
    dur   = {tid: T[tid]["dur"] for tid in T}
    itv   = {tid: m.NewIntervalVar(start[tid], dur[tid], end[tid], f"itv_{tid}") for tid in T}

    # Resource assignment (binary x[tid,rid])
    x = {(tid,rid): m.NewBoolVar(f"x_{tid}_{rid}") for tid in T for rid in R if T[tid]["skill"] in skills[rid]}

    # Each task assigned to exactly one compatible resource
    for tid in T:
        m.Add(sum(x.get((tid,rid), 0) for rid in R) == 1)

    # No overlap per resource: add an optional interval per resource
    for rid in R:
        itvs=[]
        for tid in T:
            if (tid,rid) in x:
                itvs.append(m.NewOptionalIntervalVar(start[tid], dur[tid], end[tid], x[(tid,rid)], f"itv_{tid}_{rid}"))
        m.AddNoOverlap(itvs)

    # Precedence constraints
    for tid in T:
        for dep in T[tid]["deps"]:
            m.Add(start[tid] >= end[dep])

    # Shift windows: task must lie inside a valid working window of its assigned resource
    # Simple approach: force starts inside per-day windows using big-M (demo)
    for (tid,rid), var in x.items():
        st = start[tid]
        s  = R[rid]["start"]; e = R[rid]["end"]
        # Allow any whole-day offset k; approximate by bounding st mod 24 into [s, e-dur]
        k = m.NewIntVar(0, H//24+3, f"k_{tid}_{rid}")
        m.Add(st >= s + 24*k).OnlyEnforceIf(var)
        m.Add(end[tid] <= e + 24*k).OnlyEnforceIf(var)

    # Lateness and soft penalties
    laten = {}
    for tid in T:
        ddl = T[tid]["ddl"]
        laten[tid] = m.NewIntVar(0, H, f"late_{tid}")
        m.Add(laten[tid] >= end[tid] - ddl)
        m.Add(laten[tid] >= 0)

    # Objective
    if objective == "lateness":
        m.Minimize(sum( (10*(6 - T[tid]["prio"])) * laten[tid] for tid in T))  # weight by inverse priority
    elif objective == "makespan":
        Cmax = m.NewIntVar(0, H, "Cmax"); m.AddMaxEquality(Cmax, [end[tid] for tid in T]); m.Minimize(Cmax)
    else:
        # weighted: alpha * lateness + beta * makespan
        Cmax = m.NewIntVar(0, H, "Cmax"); m.AddMaxEquality(Cmax, [end[tid] for tid in T])
        m.Minimize( 1*sum(laten.values()) + 0.1*Cmax )

    solver = cp_model.CpSolver()
    solver.parameters.max_time_in_seconds = 10.0
    solver.parameters.num_search_workers = 8

    res=[]
    status = solver.Solve(m)
    for tid in T:
        # find chosen resource
        rid = next((r for (t,r),var in x.items() if t==tid and solver.Value(var)==1), None)
        res.append({"task_id": tid, "res_id": rid, "start": solver.Value(start[tid]), "end": solver.Value(end[tid])})
    return status, res

